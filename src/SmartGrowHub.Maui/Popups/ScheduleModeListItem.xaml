<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SmartGrowHub.Maui.Popups.ScheduleModeListItem"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:popups="clr-namespace:SmartGrowHub.Maui.Popups"
    x:Name="Root"
    x:DataType="popups:ScheduleModeListItem">
    <VerticalStackLayout BindingContext="{Reference Root}" Spacing="2">
        <Label Style="{StaticResource MediumMedium}" Text="{Binding Title}" />
        <Label Style="{StaticResource SmallRegularCaption}" Text="{Binding Description}" />
    </VerticalStackLayout>
</ContentView>
